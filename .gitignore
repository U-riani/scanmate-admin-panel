# =========================
# Backend (FastAPI / Python)
# =========================
backend/__pycache__/
backend/*.py[cod]
backend/*$py.class

# Virtual environments
backend/venv/
backend/.venv/
backend/env/
backend/ENV/

# Python build / packaging
backend/build/
backend/dist/
