# Python tooling caches
backend/.pytest_cache/
backend/.mypy_cache/
backend/.ruff_cache/
backend/.coverage
backend/htmlcov/

# Jupyter / misc
backend/.ipynb_checkpoints/

# =========================
# Database / local runtime files
# =========================
backend/*.sqlite3
backend/*.db

# =========================
